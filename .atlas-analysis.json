  "keyFeatures": [
    "Colorize calendar events based on event type/category color",
    "Improved description layout for calendar events (dedicated tab)",
    "Export Odoo calendar events to a standard ICS file",
    "Import ICS files to create or update Odoo calendar events with UID-based idempotency",
    "Manage country- and region-aware public holidays with automatic calendar event creation",
    "Full resource booking and appointment scheduling system with portal access",
    "Automated resource combination availability checking with conflict detection",
    "Configurable modification deadlines, slot durations, and multi-company support"
  ],
  "publicApiSurface": [
    "calendar.public.holiday.get_holidays_list(year, start_dt, end_dt, partner_id)",
