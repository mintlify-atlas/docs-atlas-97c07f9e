    "resource.booking (model) — create/confirm/cancel bookings",
    "resource.booking.type (model) — configure booking categories and rules",
    "resource.booking.combination (model) — define bookable resource groups",
    "resource.booking.combination._get_intervals(start_dt, end_dt, tz)",
    "resource.resource.is_available(start_dt, end_dt)",
    "calendar.export.ics wizard (generate_ics_content)",
    "calendar.import.ics wizard (button_import)",
    "Portal routes: /my/bookings, /my/bookings/<id>, /my/bookings/<id>/schedule, /my/bookings/<id>/confirm, /my/bookings/<id>/cancel"
  ]
